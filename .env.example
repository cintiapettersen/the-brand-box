# Google Gemini API
GEMINI_API_KEY=

# OpenAI Creative Director
# Use a server-side key only. Do not prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=
# This model is used by the Creative Director diagnosis, refinement, palette,
# and tagline routes. Keep it set in every environment where those features run.
OPENAI_MODEL=gpt-4.1-mini

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
