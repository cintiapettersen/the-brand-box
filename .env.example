# Google Gemini API
GEMINI_API_KEY=

# OpenAI Creative Director
# Use a server-side key only. Do not prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=
# Required. There is no runtime model fallback; this example is not a default.
# Set the model enabled for your OpenAI project in each environment.
OPENAI_MODEL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
